{
  "agents": {
    "defaults": {
      "workspace": "~/.nanobot/workspace",
      "model": "gpt-4o-mini",
      "provider": "openai",
      "maxTokens": 8192,
      "temperature": 0.1,
      "maxToolIterations": 40,
      "memoryWindow": 100
    }
  },
  "providers": {
    "openai": {
      "apiKey": ""
    },
    "anthropic": {
      "apiKey": ""
    },
    "openrouter": {
      "apiKey": ""
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790
  },
  "tools": {
    "web": {
      "search": {
        "apiKey": "",
        "serpApiKey": ""
      }
    },
    "restrictToWorkspace": false
  },
  "integrations": {
    "google": {
      "clientId": "",
      "clientSecret": "",
      "redirectUri": "http://localhost:8765/integrations/callback"
    }
  },
  "channels": {
    "sendProgress": true,
    "sendToolHints": false
  },
  "authEnabled": true
}
